---
import Nav from "../components/Nav.astro";
---

<style>
    footer {
        row-gap: 1rem;
    }
</style>

<footer
    class="footer footer-horizontal footer-center text-base-content p-10 bg-secondary/10 border-t border-neutral/20"
>
    <nav class="grid grid-flow-col gap-4">
        <ul class="menu menu-horizontal">
            <Nav />
        </ul>
    </nav>

    <aside>
        <p>
            Copyright © {new Date().getFullYear()} - All right reserved by Renegade
            Derby Dames
        </p>
        <p>
            The Renegade Derby Dames are members of the Women's Flat Track
            Roller Derby Association.
        </p>
        <p>49 Nelson St. West in Downtown Alliston, Ontario</p>
    </aside>
</footer>
