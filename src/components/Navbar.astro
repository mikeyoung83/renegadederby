---
// src/components/Navbar.astro
import Nav from "../components/Nav.astro";
import Logo from "./Logo.astro";
---

<div
    id="main-navbar"
    class="navbar bg-base-100 sticky top-0 z-50 overflow-visible py-0!"
>
    <div class="mx-auto max-w-7xl px-6 lg:px-8 w-full flex items-center h-22.5">
        <div class="flex-1 self-start">
            <a href="/" aria-label="Derby Home" class="inline-block">
                <Logo />
            </a>
        </div>
        <div class="flex-none md:hidden">
            <label
                for="my-drawer-2"
                aria-label="open sidebar"
                class="btn btn-square btn-ghost"
            >
                <span class="sr-only">Sidebar icon</span>
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    class="inline-block h-6 w-6 stroke-current"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </label>
        </div>
        <div class="flex-none flex items-center gap-4">
            <ul class="menu menu-horizontal px-1 font-medium hidden md:flex">
                <Nav />
            </ul>
        </div>
    </div>
</div>

<div class="drawer">
    <label for="my-drawer-2" class="sr-only">Toggle navigation drawer</label>

    <input
        id="my-drawer-2"
        type="checkbox"
        class="drawer-toggle"
        aria-label="Toggle navigation drawer"
    />

    <div class="drawer-side">
        <button
            type="button"
            class="drawer-overlay"
            aria-label="close sidebar"
            onclick="document.getElementById('my-drawer-2').click()"
        >
            <span class="sr-only">Close navigation menu</span>
        </button>

        <nav class="menu bg-base-200 min-h-full w-80 p-4 pt-40 z-50">
            <ul class="text-2xl">
                <Nav />
            </ul>
        </nav>
    </div>
</div>

<style is:global>
    .logo-img {
        height: 220px;
        width: auto;
        transform-origin: top left;
        will-change: transform;
        transform: scale(calc(80 / 220));
    }

    #main-navbar.at-top .logo-img {
        transform: scale(1);
    }

    @media (min-width: 1024px) {
        #main-navbar.ready .logo-img {
            transition: transform 0.4s ease-in-out;
        }
    }

    @media (max-width: 1023px) {
        #main-navbar.at-top .logo-img {
            transform: scale(calc(80 / 220));
        }
    }
</style>

<script is:inline>
    (function () {
        if (window.scrollY <= 10) {
            var el = document.getElementById("main-navbar");
            if (el) el.classList.add("at-top");
        }
    })();
</script>

<script>
    const currentPath = window.location.pathname;
    const navLinks = document.querySelectorAll(".navbar a");

    navLinks.forEach((link) => {
        const href = link.getAttribute("href");
        if (!href) return;

        if (
            href === currentPath ||
            (href !== "/" && currentPath.startsWith(href))
        ) {
            link.classList.add("active");
            link.classList.add("text-primary", "font-bold");
        }
    });

    const navbar = document.getElementById("main-navbar");

    const handleScroll = () => {
        if (window.scrollY <= 10) {
            navbar?.classList.add("at-top");
        } else {
            navbar?.classList.remove("at-top");
        }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();

    requestAnimationFrame(() => {
        navbar?.classList.add("ready");
    });
</script>
