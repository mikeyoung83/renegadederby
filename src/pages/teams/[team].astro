---
import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
    const allTeams = await getCollection("teams");
    const allPlayers = await getCollection("players");

    return allTeams.map((team) => {
        // Filter players whose ID starts with this team's slug (e.g., "bombshells/")
        const teamPlayers = allPlayers.filter((p) =>
            p.id.startsWith(`${team.id}/`),
        );

        return {
            params: { team: team.id },
            props: { team, players: teamPlayers },
        };
    });
}

const { team, players } = Astro.props;
const { Content } = await render(team); // This handles the Markdown links/text
---

<MainLayout title={team.data.name}>
    <div class="relative isolate overflow-hidden py-24 sm:py-32">
        <img
            src={team.data.groupPhoto.src}
            alt={`Group photo of ${team.data.name}`}
            class="absolute inset-0 -z-10 size-full object-cover"
        />
        <div
            class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"
        >
        </div>

        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-2xl lg:mx-0 relative">
                <img src={team.data.logo.src} alt="" class="logo" />
                <h2
                    class="text-5xl font-semibold tracking-tight text-white sm:text-7xl inline"
                >
                    {team.data.name}
                </h2>
                <p
                    class="mt-8 text-lg font-medium text-pretty text-gray-400 sm:text-xl/8"
                >
                    <Content />
                </p>
            </div>
        </div>
    </div>

    <div class="py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-2xl lg:mx-0">
                <h2
                    class="text-3xl uppercase tracking-tight text-pretty text-white sm:text-4xl"
                >
                    Our team
                </h2>
            </div>
            <ul
                role="list"
                class="mx-auto mt-8 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-14 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3 xl:grid-cols-4"
            >
                {
                    players.map((player) => (
                        <li>
                            <img
                                src={player.data.photo.src}
                                alt={player.data.name}
                            />
                            <h3 class="mt-3 text-lg/8 font-semibold tracking-tight text-white">
                                {player.data.name}{" "}
                                <span class="num">#{player.data.number}</span>
                            </h3>
                        </li>
                    ))
                }
            </ul>
        </div>
    </div>
</MainLayout>

<style>
    .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem;
    }
    .team-hero {
        text-align: center;
        margin-bottom: 4rem;
    }
    .logo {
        width: 120px;
        height: auto;
        margin-bottom: 1rem;
    }
    .group-photo-wrapper img {
        width: 100%;
        border-radius: 12px;
        margin: 2rem 0;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }
    .team-description {
        font-size: 1.1rem;
        line-height: 1.6;
        max-width: 600px;
        margin: 0 auto;
        text-align: left;
    }
    /* Style Markdown links */
    .team-description :global(a) {
        color: #ff4757;
        text-decoration: underline;
    }
    .player-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 2rem;
        margin-top: 2rem;
    }
    .player-card img {
        width: 100%;
        aspect-ratio: 1;
        object-fit: cover;
        border-radius: 8px;
    }
    .num {
        font-size: 0.9rem;
        color: #666;
    }
</style>
