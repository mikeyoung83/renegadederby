---
import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { Image } from "astro:assets";
import fallbackPhoto from "../../assets/placeholder-player.jpg";

export async function getStaticPaths() {
    const allTeams = await getCollection("teams");
    const allPlayers = await getCollection("players");
    const allCoaches = await getCollection("coaches");

    return allTeams.map((team) => {
        // 1. Filter players for this team
        // 2. Sort them by number (Ascending)
        const teamPlayers = allPlayers
            .filter((p) => p.id.startsWith(`${team.id}/`))
            .sort((a, b) => a.data.number - b.data.number);

        // Filter coaches for this team
        const teamCoaches = allCoaches.filter((c) =>
            c.id.startsWith(`${team.id}/`),
        );

        return {
            params: { team: team.id },
            props: { team, players: teamPlayers, coaches: teamCoaches },
        };
    });
}

const { team, players, coaches } = Astro.props;
const { Content } = await render(team); // This handles the Markdown links/text
const socials = team.data.socials;
---

<MainLayout title={team.data.name}>
    <div class="relative isolate overflow-hidden py-24 sm:py-28">
        <Image
            src={team.data.groupPhoto}
            decoding="async"
            loading="eager"
            fetchpriority="high"
            width={1800}
            alt={`Group photo of ${team.data.name}`}
            class="absolute inset-0 -z-10 size-full object-cover"
        />
        <div
            class="absolute inset-0 bg-gradient-to-t from-black/98 via-black/60 to-transparent"
        >
        </div>

        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-2xl lg:mx-0 relative">
                <Image
                    src={team.data.logo}
                    decoding="async"
                    loading="eager"
                    fetchpriority="high"
                    width={150}
                    alt={`Logo of ${team.data.name}`}
                    class="w-30 mb-4"
                />
                <h2
                    class="text-5xl font-semibold tracking-tight text-white sm:text-7xl inline"
                >
                    {team.data.name}
                </h2>
                <p
                    class="mt-8 text-lg font-medium text-pretty text-gray-400 sm:text-xl/8"
                >
                    <Content />
                </p>
                {
                    socials && (
                        <div class="flex gap-6 mt-4">
                            {socials.facebook && (
                                <a
                                    href={socials.facebook}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-slate-400 hover:text-blue-600 transition-colors"
                                >
                                    <span class="sr-only">Facebook</span>
                                    <svg
                                        class="w-6 h-6"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" />
                                    </svg>
                                </a>
                            )}

                            {socials.instagram && (
                                <a
                                    href={socials.instagram}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-slate-400 hover:text-pink-500 transition-colors"
                                >
                                    <span class="sr-only">Instagram</span>
                                    <svg
                                        class="w-6 h-6"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
                                    </svg>
                                </a>
                            )}

                            {socials.twitter && (
                                <a
                                    href={socials.twitter}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-slate-400 hover:text-blue-400 transition-colors"
                                >
                                    <span class="sr-only">Twitter</span>
                                    <svg
                                        class="w-6 h-6"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.84 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z" />
                                    </svg>
                                </a>
                            )}
                        </div>
                    )
                }
            </div>
        </div>
    </div>

    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-24 sm:py-32">
        <div
            class="grid grid-cols-1 gap-x-12 gap-y-16 lg:grid-cols-4 items-start"
        >
            <div class="lg:col-span-3">
                <div class="mx-auto max-w-2xl lg:mx-0">
                    <h2
                        class="text-3xl uppercase tracking-tight text-pretty text-white sm:text-4xl"
                    >
                        Our team
                    </h2>
                </div>
                <ul
                    role="list"
                    class="mx-auto mt-8 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-14 sm:grid-cols-3 lg:mx-0 lg:max-w-none xl:grid-cols-4"
                >
                    {
                        players.map((player) => (
                            <li>
                                <div class="relative w-full">
                                    <div class="absolute rounded-2xl inset-0 -mt-2 -ml-2 bg-secondary" />
                                    <Image
                                        src={player.data.photo || fallbackPhoto}
                                        alt={player.data.name}
                                        width={400}
                                        class="relative z-10 aspect-3/4 w-full object-cover rounded-2xl"
                                    />
                                </div>

                                <h3 class="mt-3 text-lg/8 font-bold sm:text-xl">
                                    <span class="font-normal text-white text-sm align-middle block">
                                        #{player.data.number}
                                    </span>
                                    {player.data.name}
                                </h3>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <aside class="lg:col-span-1 sticky top-8">
                <div class="mx-auto max-w-2xl lg:mx-0">
                    <h2
                        class="text-3xl uppercase tracking-tight text-pretty text-white sm:text-4xl"
                    >
                        Our Coaches
                    </h2>
                </div>
                <ul
                    role="list"
                    class="mx-auto max-w-2xl lg:mx-0 mt-4 grid grid-cols-1 gap-y-2 lg:mx-0"
                >
                    {
                        coaches.map((coach) => (
                            <li>
                                <h3 class="mt-3 text-lg/8 font-bold sm:text-xl">
                                    {coach.data.name}
                                </h3>
                            </li>
                        ))
                    }
                </ul>
            </aside>
        </div>
    </div>
</MainLayout>
