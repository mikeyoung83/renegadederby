---
import MainLayout from "../layouts/MainLayout.astro";
const items = [
    {
        src: "https://images.unsplash.com/photo-1640469262892-183628a6ef33?q=80&w=1364&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
        alt: "Client 1",
    },
    {
        src: "https://plus.unsplash.com/premium_photo-1664444389231-c1109b2193a3?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
        alt: "Client 2",
    },
    {
        src: "https://upload.wikimedia.org/wikipedia/commons/0/0a/WasatchVsJunctionCity.jpg",
        alt: "Client 3",
    },
];
---

<MainLayout title="Home" description="change meta tag">
    <section class="relative overflow-hidden">
        <div class="mx-auto max-w-7xl">
            <div class="relative z-10 lg:w-full lg:max-w-2xl">
                <svg
                    class="absolute inset-y-0 right-8 hidden h-full w-80 translate-x-1/2 transform fill-base-100 lg:block"
                    viewBox="0 0 100 100"
                    preserveAspectRatio="none"
                    aria-hidden="true"
                >
                    <polygon points="0,0 90,0 50,100 0,100"></polygon>
                </svg>

                <div
                    class="relative px-6 py-32 sm:py-40 lg:px-8 lg:py-20 lg:pr-0"
                >
                    <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-xl">
                        <div class="hidden sm:mb-10 sm:flex">
                            <div
                                class="relative rounded-full px-3 py-1 text-sm/6 ring-1 ring-accent"
                            >
                                Upcoming game or news or something. <a
                                    href="#"
                                    class="font-semibold whitespace-nowrap"
                                    ><span
                                        class="absolute inset-0"
                                        aria-hidden="true"></span>Read more <span
                                        aria-hidden="true">&rarr;</span
                                    ></a
                                >
                            </div>
                        </div>
                        <h1
                            class="text-6xl font-semibold tracking-tight text-pretty sm:text-9xl text-white uppercase"
                        >
                            Renegade Derby Dames
                        </h1>
                        <p
                            class="mt-8 text-lg font-medium text-pretty sm:text-xl/8"
                        >
                            Established in 2011, Renegade Derby Dames is Simcoe
                            County's first flat-track roller derby league.
                        </p>
                        <div class="mt-10 flex items-center gap-x-6">
                            <a href="/contact" class="btn btn-secondary"
                                >View Schedule</a
                            >
                            <a
                                href="/contact"
                                class="btn btn-accent btn-outline text-accent"
                                >Curious To Join?</a
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="lg:absolute lg:inset-y-0 lg:right-0 lg:w-1/2">
            <div class="carousel w-full h-full">
                {
                    items.map((item) => (
                        <div class="carousel-item w-full h-full">
                            <img
                                src={item.src}
                                alt={item.alt}
                                class="object-cover w-full h-full"
                            />
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="overflow-hidden bg-base-300">
        <div
            class="mx-auto max-w-4xl px-6 lg:flex lg:px-8 lg:py-12 sm:py-9 py-9 justify-items-center"
        >
            <div
                class="grid grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:grid-cols-2 lg:items-start"
            >
                <div class="sm:px-6 lg:px-0">
                    <span class="text-base/6 font-semibold text-accent"
                        >About Us
                    </span>
                    <h2
                        class="mt-2 text-4xl/12 font-semibold text-pretty sm:text-5xl/14 text-white uppercase mb-8"
                    >
                        A league run for the skaters, by the skaters.
                    </h2>
                    <a href="/contact" class="btn btn-secondary">Learn More</a>
                </div>

                <div class="sm:px-6 lg:px-6">
                    <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-lg">
                        <p class="ext-lg/8 mt-8">
                            We created a non-profit organization, based on
                            democratic principles, operating as part of the
                            larger derby community. We are proud to have become
                            a full member league of the Women’s Flat Track Derby
                            Association in March of 2014, which means that we
                            joined the ranks of 470 women-led, skater owned and
                            operated leagues worldwide that have united to lead
                            the sport of women’s flat track roller derby.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="overflow-hidden py-24 sm:py-32">
        <div class="mx-auto max-w-7xl md:px-6 lg:px-8 prose">
            <div
                class="grid grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:grid-cols-2 lg:items-start"
            >
                <div class="px-6 lg:px-0 lg:pt-4 lg:pr-4">
                    <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-lg">
                        <p
                            class="mt-2 text-2xl font-semibold tracking-tight text-pretty sm:text-4xl"
                        >
                            2026 Home Game Schedule
                        </p>
                        <p class="mt-6 text-lg/8">
                            <b>March 28, 2026: Home Opener Triple Header</b><br
                            />
                            <ul>
                                <li>
                                    South Simcoe Jr. Rollerderby Vs. Hogtown Jr.
                                    Jawbreakers
                                </li>
                                <li>
                                    Bombshell Battalion vs. Hogtown Debu-Taunts
                                </li>
                                <li>Striking Vikings vs. Hogtown Horror</li>
                            </ul>
                        </p>
                        <p class="mt-6 text-lg/8">
                            Click here for our 2026 schedule. More games to be
                            announced! Stay tuned!
                        </p>
                    </div>
                </div>
                <div class="sm:px-6 lg:px-0">
                    <div class="mx-auto max-w-2xl">
                        <img
                            src="https://tailwindui.com/plus-assets/img/component-images/project-app-screenshot.png"
                            alt="Product screenshot"
                            width="2432"
                            height="1442"
                            class="w-full h-auto rounded-xl"
                        />
                    </div>
                </div>
            </div>
        </div>
        <hr class="border-t border-gray-300 mx-auto max-w-7xl mt-12 mb-12" />
        <div class="mx-auto max-w-7xl md:px-6 lg:px-8">
            <div
                class="grid grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:grid-cols-2 lg:items-start"
            >
                <div class="px-6 lg:px-0 lg:pt-4 lg:pr-4">
                    <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-lg">
                        <p
                            class="mt-2 text-2xl font-semibold tracking-tight text-pretty sm:text-4xl"
                        >
                            Show latest content here
                        </p>
                        <p class="mt-6 text-lg/8">
                            <b>Date: name of thing</b><br />
                        </p>
                        <p class="mt-6 text-lg/8">
                            Kinda like what's on the current site homepage.
                        </p>
                    </div>
                </div>
                <div class="sm:px-6 lg:px-0">
                    <div class="mx-auto max-w-2xl">
                        <img
                            src="https://tailwindui.com/plus-assets/img/component-images/project-app-screenshot.png"
                            alt="Product screenshot"
                            width="2432"
                            height="1442"
                            class="w-full h-auto rounded-xl"
                        />
                    </div>
                </div>
            </div>
        </div>
    </section>
</MainLayout>

<script>
    const carousel = document.querySelector(".carousel") as HTMLElement;
    let index = 0;
    let intervalId: number | undefined;

    const startScrolling = () => {
        if (!intervalId && carousel) {
            intervalId = window.setInterval(() => {
                const items = carousel.querySelectorAll(".carousel-item");
                if (items.length > 0) {
                    index = (index + 1) % items.length;

                    // GET THE TARGET ITEM
                    const targetItem = items[index] as HTMLElement;

                    // CALCULATE THE SCROLL POSITION
                    // This moves the "left" edge of the carousel to the "left" edge of the item
                    carousel.scrollTo({
                        left: targetItem.offsetLeft,
                        behavior: "smooth",
                    });
                }
            }, 6000);
        }
    };

    const stopScrolling = () => {
        if (intervalId) {
            clearInterval(intervalId);
            intervalId = undefined;
        }
    };

    if (carousel) {
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) startScrolling();
                    else stopScrolling();
                });
            },
            { threshold: 0.1 },
        );

        observer.observe(carousel);
    }
</script>
